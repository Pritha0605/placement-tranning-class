import java.util.*;
import java.io.*;

class Solution{
    public static void main(String []argh){
        Scanner in = new Scanner(System.in);
        int t = in.nextInt();
        for(int i = 0; i < t; i++){
            int a = in.nextInt();
            int b = in.nextInt();
            int n = in.nextInt();
            
            // Start of the inner logic to generate the series
            int sum = a;
            for (int j = 0; j < n; j++) {
                // Calculate the current term to add using Math.pow
                // Math.pow returns a double, so cast it to an int
                sum += (int)Math.pow(2, j) * b; 
                System.out.print(sum + " ");
            }
            // Print a new line after each series is generated
            System.out.println(); 
            // End of the inner logic
            
        }
        in.close();
    }
}
